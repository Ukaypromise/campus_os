


<div class="flex items-center justify-center h-full">
  <div class="w-full max-w-md p-8">
    <h2 class="text-center text-3xl font-semibold mb-2">Sign in to your account</h2>
    <p class="text-center text-sm text-gray-600 mb-8">or <%= link_to "create an account", new_registration_path(resource_name), class:"text-blue-600 hover:underline" %></p>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "max-w-md mx-auto space-y-4" }) do |f| %>
      <% if flash[:notice] %>
        <div class="bg-blue-100 text-blue-800 p-3 rounded-lg mb-4">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <div>
        <%= f.label :email, "Email address", class: "block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full p-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600" %>
      </div>
      <div>
        <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "mt-1 block w-full p-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600" %>
      </div>
      <% if devise_mapping.rememberable? %>
        <div class="flex items-center">
          <div>
            <%= f.check_box :remember_me, class: "text-blue
            -600" %>
            <%= f.label :remember_me, class: "text-sm text-gray-600" %>
          </div>
        </div>
      <% end %>
      <div>
        <%= f.submit "Log in", class: "w-full bg-black text-white font-semibold py-2.5 rounded-lg mt-4 hover:bg-gray-800 focus:outline-none cursor-pointer " %>
      </div>
    <% end %>
    <div class="mt-4 text-center text-sm text-gray-600">
      <%= link_to "Forgot your password?", new_password_path(resource_name), class:"text-blue-600 hover:underline" %> or
      <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class:"text-blue-600 hover:underline" %>
    </div>
    <div class="mt-8 text-center text-xs text-gray-500">
      Privacy Policy • Terms of Service
    </div>
  </div>
</div>
