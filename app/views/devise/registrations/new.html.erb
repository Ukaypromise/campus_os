<div class="flex items-center justify-center h-full">
  <div class="w-full max-w-md p-8">
    <h2 class="text-center text-3xl font-semibold mb-2">Create an account</h2>
    <p class="text-center text-sm text-gray-600 mb-8">or <%= link_to "sign in to your account", new_session_path(resource_name), class:"text-blue-600 hover:underline" %></p>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "max-w-md mx-auto space-y-4" }) do |f| %>
      <% if resource.errors.any? %>
        <div class="bg-red-100 text-red-800 p-3 rounded-lg mb-4">
          <%= render "devise/shared/error_messages", resource: resource %>
        </div>
      <% end %>
      <div>
        <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full p-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600" %>
      </div>
      <div>
        <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700" %>
        <% if @minimum_password_length %>
          <em class="text-xs text-gray-500">(<%= @minimum_password_length %> characters minimum)</em>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 block w-full p-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600" %>
      </div>
      <div>
        <%= f.label :password_confirmation, "Password Confirmation", class: "block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-full p-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600" %>
      </div>
      <div>
        <%= f.submit "Continue", class: "w-full bg-black text-white font-semibold py-2.5 rounded-lg mt-4 hover:bg-gray-800 focus:outline-none" %>
      </div>
    <% end %>
    <div class="mt-8 text-center text-xs text-gray-500">
      Privacy Policy • Terms of Service
    </div>
  </div>
</div>