<div id="<%= dom_id institution %>" class="my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= institution.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Phone number:</strong>
    <%= institution.phone_number %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Contact email:</strong>
    <%= institution.contact_email %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Website:</strong>
    <%= institution.website %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Address:</strong>
    <%= institution.address %>
  </div>
  <div>
    <strong class="block font-medium mb-1">City:</strong>
    <%= institution.city %>
  </div>
  <div>
    <strong class="block font-medium mb-1">State:</strong>
    <%= institution.state %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Country:</strong>
    <%= institution.country %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Account:</strong>
    <%= institution.account_id %>
  </div>
</div>
