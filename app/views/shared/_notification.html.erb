<% type = type.to_sym %>

<%= tag.div class: "flex gap-3 rounded-lg border bg-white p-4 group max-w-80 shadow-xs border-alpha-black-25",
            data: {
              controller: "element-removal",
            } do %>

  <div class="h-5 w-5 shrink-0 p-px text-white">
    <% case type %> 
    <% when :notice %>
      <div class="flex h-full items-center justify-center rounded-full bg-green-700">
        <%= notice_icon("w-3 h-3")%>
      </div>
    <% when :alert %>
      <div class="flex h-full items-center justify-center rounded-full bg-red-700">
        <%= alert_icon("w-3 h-3")%>
      </div>
    <% end %>
  </div>

  <%= tag.p message, class: "text-gray-900 text-sm font-medium" %>

  <div class="ml-auto">
    <% if type.to_sym == :notice %>
      <div class="h-5 shrink-0">
        <div class="absolute -top-2 -right-2">
          <span data-action="click->element-removal#remove" class="p-0.5 hidden group-hover:inline-block border border-alpha-black-50 border-solid rounded-lg bg-white text-gray-400 cursor-pointer">
            <%= close_icon("w-5 h-5") %>
          </span>
        </div>
      </div>
    <% elsif type.to_sym == :alert %>
      <span data-action="click->element-removal#remove" class="text-gray-500 hover:text-gray-600 cursor-pointer">
        <%= close_icon_top("w-5 h-5") %>
      </span>
    <% end %>
  </div>
<% end %>