<dialog id="turbo_confirm" class=" relative z-50 rounded-xl">
  <div class="fixed inset-0 bg-white bg-opacity-75 transition-opacity"></div>
  <form method="dialog" class="flex min-h-full items-end justify-center text-center sm:items-center">
    <div class="flex min-h-full items-end justify-center text-center sm:items-center">
      <div class="relative transform overflow-hidden rounded-xl bg-white px-6 pb-4 pt-4 text-left shadow-xl transition-all sm:w-full sm:max-w-2xl sm:p-8">
        <button value="cancel" class="absolute top-2 right-2 text-gray-500 hover:text-gray-600 cursor-pointer">
          <%= close_icon_top("w-5 h-5") %>
        </button>
        <div class="sm:flex flex-col sm:items-start ">
          <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left">
            <p class="text-lg font-semibold text-gray-900">Are you sure? </p>
          </div>
          <p class="ml-4 text-gray-500 text-sm mt-2">This action cannot be undone.</p>
        </div>
        <div class="flex justify-between space-x-3 mt-6">
          <button value="cancel" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-900 font-medium hover:bg-gray-100"> Cancel </button>
          <button value="confirm" class="px-4 py-2 bg-red-500 text-white font-medium rounded-lg flex items-center gap-2 hover:bg-red-700">
            <%= delete_icon("w-5 h-5") %> <span id="delete-text">Delete</span>
          </button>
        </div>
      </div>
    </div>
  </form>
</dialog>
